#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f -- "${BASH_SOURCE[0]}" 2>/dev/null || realpath -- "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)"
BIN="$SCRIPT_DIR/target/release/copy-rs"

if [[ ! -x "$BIN" || "$SCRIPT_DIR/src/main.rs" -nt "$BIN" || "$SCRIPT_DIR/Cargo.toml" -nt "$BIN" || "$SCRIPT_DIR/.cargo/config.toml" -nt "$BIN" ]]; then
  cargo build --release --quiet --manifest-path "$SCRIPT_DIR/Cargo.toml"
fi

exec "$BIN" "$@"
